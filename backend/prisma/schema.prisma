generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum EventImageKind {
  COVER
  GALLERY
}

enum TicketUnitStatus {
  AVAILABLE
  HELD
  SOLD
}

enum CheckoutStatus {
  ACTIVE
  CONFIRMED
  CANCELLED
  EXPIRED
  ABANDONED
}

enum OrderStatus {
  CONFIRMED
  CANCELLED_BY_CUSTOMER
  CANCELLED_BY_EVENT
}

enum TicketStatus {
  ISSUED
  USED
  CANCELLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}
enum AuditAction {
  ORGANIZER_INVITED
  ORGANIZER_INVITE_ACCEPTED
  STAFF_INVITED
  STAFF_INVITE_ACCEPTED
  EVENT_PUBLISHED
  EVENT_CANCELLED
  CAPACITY_CHANGED
  CHECKOUT_CREATED
  CHECKOUT_CANCELLED
  CHECKOUT_EXPIRED
  CHECKOUT_ABANDONED
  ORDER_CONFIRMED
  ORDER_CANCELLED
  TICKET_VALIDATED
}

model User {
  id            String    @id @default(uuid()) @db.Char(36)
  name          String    @db.VarChar(160)
  email         String    @unique @db.VarChar(255)
  emailVerified Boolean   @default(false)
  image         String?   @db.VarChar(2048)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String    @default("customer") @db.VarChar(255)
  banned        Boolean   @default(false)
  banReason     String?   @db.VarChar(500)
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]
  profile       UserProfile?
  events        Event[]
  checkouts     Checkout[]
  orders        Order[]
  tickets       IssuedTicket[]
  staffLinks    EventStaff[]
}

model Session {
  id             String   @id @default(uuid()) @db.Char(36)
  expiresAt      DateTime
  token          String   @unique @db.VarChar(255)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?  @db.VarChar(64)
  userAgent      String?  @db.Text
  userId         String   @db.Char(36)
  impersonatedBy String?  @db.Char(36)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Account {
  id                    String    @id @default(uuid()) @db.Char(36)
  accountId             String    @db.VarChar(255)
  providerId            String    @db.VarChar(100)
  userId                String    @db.Char(36)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(uuid()) @db.Char(36)
  identifier String   @db.VarChar(255)
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([identifier])
}

model UserProfile {
  userId          String   @id @db.Char(36)
  phone           String   @db.VarChar(20)
  cpfEncrypted    String   @db.Text
  cpfHash         String   @unique @db.Char(64)
  postalCode      String   @db.Char(8)
  street          String   @db.VarChar(180)
  number          String   @db.VarChar(20)
  complement      String?  @db.VarChar(100)
  district        String   @db.VarChar(100)
  city            String   @db.VarChar(100)
  state           String   @db.Char(2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventCategory {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @unique @db.VarChar(80)
  slug      String   @unique @db.VarChar(100)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events    Event[]
}

model Event {
  id           String      @id @default(uuid()) @db.Char(36)
  organizerId  String      @db.Char(36)
  categoryId   String      @db.Char(36)
  title        String      @db.VarChar(180)
  slug         String      @unique @db.VarChar(220)
  description  String      @db.Text
  venueName    String      @db.VarChar(180)
  postalCode   String      @db.Char(8)
  street       String      @db.VarChar(180)
  number       String      @db.VarChar(20)
  complement   String?     @db.VarChar(100)
  district     String      @db.VarChar(100)
  city         String      @db.VarChar(100)
  state        String      @db.Char(2)
  startsAt     DateTime
  endsAt       DateTime
  timezone     String      @default("America/Sao_Paulo") @db.VarChar(80)
  status       EventStatus @default(DRAFT)
  publishedAt  DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  organizer    User        @relation(fields: [organizerId], references: [id], onDelete: Restrict)
  category     EventCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images       EventImage[]
  ticketTypes  TicketType[]
  checkouts    Checkout[]
  orders       Order[]
  tickets      IssuedTicket[]
  staff        EventStaff[]
  staffInvites StaffInvitation[]
  @@index([status, startsAt])
  @@index([categoryId, startsAt])
  @@index([organizerId, createdAt])
  @@index([city, startsAt])
}

model EventImage {
  id        String         @id @default(uuid()) @db.Char(36)
  eventId   String         @db.Char(36)
  objectKey String         @unique @db.VarChar(500)
  mimeType  String         @db.VarChar(80)
  size      Int
  kind      EventImageKind
  position  Int
  createdAt DateTime       @default(now())
  event     Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  @@unique([eventId, position])
  @@index([eventId, kind])
}

model TicketType {
  id           String   @id @default(uuid()) @db.Char(36)
  eventId      String   @db.Char(36)
  name         String   @db.VarChar(120)
  description  String?  @db.VarChar(500)
  priceCents   Int
  capacity     Int
  maxPerOrder  Int      @default(10)
  saleStartsAt DateTime?
  saleEndsAt   DateTime?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  units        TicketUnit[]
  checkoutItems CheckoutItem[]
  orderItems   OrderItem[]
  @@unique([eventId, name])
  @@index([eventId, active])
}

model TicketUnit {
  ticketTypeId String           @db.Char(36)
  sequence     Int
  status       TicketUnitStatus @default(AVAILABLE)
  checkoutId   String?          @db.Char(36)
  updatedAt    DateTime         @updatedAt
  ticketType   TicketType       @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  checkout     Checkout?        @relation(fields: [checkoutId], references: [id], onDelete: SetNull)
  @@id([ticketTypeId, sequence])
  @@index([ticketTypeId, status, sequence])
  @@index([checkoutId])
}

model Checkout {
  id              String         @id @default(uuid()) @db.Char(36)
  userId          String         @db.Char(36)
  eventId         String         @db.Char(36)
  status          CheckoutStatus @default(ACTIVE)
  totalCents      Int
  expiresAt       DateTime
  lastHeartbeatAt DateTime
  terminalReason  String?        @db.VarChar(100)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  confirmedAt     DateTime?
  user            User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  event           Event          @relation(fields: [eventId], references: [id], onDelete: Restrict)
  items           CheckoutItem[]
  units           TicketUnit[]
  order           Order?
  @@index([userId, status])
  @@index([status, expiresAt])
  @@index([status, lastHeartbeatAt])
  @@index([eventId, createdAt])
}

model CheckoutItem {
  checkoutId       String @db.Char(36)
  ticketTypeId     String @db.Char(36)
  quantity         Int
  unitPriceCents   Int
  ticketTypeName   String @db.VarChar(120)
  checkout         Checkout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  ticketType       TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  @@id([checkoutId, ticketTypeId])
}

model Order {
  id               String      @id @default(uuid()) @db.Char(36)
  publicId         String      @unique @db.VarChar(30)
  checkoutId       String      @unique @db.Char(36)
  userId           String      @db.Char(36)
  eventId          String      @db.Char(36)
  status           OrderStatus @default(CONFIRMED)
  totalCents       Int
  currency         String      @default("BRL") @db.Char(3)
  eventTitle       String      @db.VarChar(180)
  eventStartsAt    DateTime
  customerName     String      @db.VarChar(160)
  customerEmail    String      @db.VarChar(255)
  customerCpfLast4 String      @db.Char(4)
  customerSnapshot Json
  paymentProvider  String      @default("SIMULATED") @db.VarChar(40)
  createdAt        DateTime    @default(now())
  cancelledAt      DateTime?
  checkout         Checkout    @relation(fields: [checkoutId], references: [id], onDelete: Restrict)
  user             User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  event            Event       @relation(fields: [eventId], references: [id], onDelete: Restrict)
  items            OrderItem[]
  @@index([userId, createdAt])
  @@index([eventId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id             String   @id @default(uuid()) @db.Char(36)
  orderId        String   @db.Char(36)
  ticketTypeId   String   @db.Char(36)
  ticketTypeName String   @db.VarChar(120)
  unitPriceCents Int
  quantity       Int
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType     TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  tickets        IssuedTicket[]
  @@index([orderId])
}

model IssuedTicket {
  id              String       @id @default(uuid()) @db.Char(36)
  publicId        String       @unique @db.VarChar(40)
  orderItemId     String       @db.Char(36)
  ownerId         String       @db.Char(36)
  eventId         String       @db.Char(36)
  ticketTypeId    String       @db.Char(36)
  unitSequence    Int
  status          TicketStatus @default(ISSUED)
  validatedAt     DateTime?
  validatedById   String?      @db.Char(36)
  createdAt       DateTime     @default(now())
  orderItem       OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  owner           User         @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  event           Event        @relation(fields: [eventId], references: [id], onDelete: Restrict)
  @@index([ownerId, createdAt])
  @@index([eventId, status])
  @@index([ticketTypeId, unitSequence])
}

model OrganizerInvitation {
  id          String           @id @default(uuid()) @db.Char(36)
  email       String           @db.VarChar(255)
  tokenHash   String           @unique @db.Char(64)
  invitedById String           @db.Char(36)
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  @@index([email, status])
}

model StaffInvitation {
  id          String           @id @default(uuid()) @db.Char(36)
  eventId     String           @db.Char(36)
  email       String           @db.VarChar(255)
  tokenHash   String           @unique @db.Char(64)
  invitedById String           @db.Char(36)
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  event       Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  @@index([email, status])
  @@index([eventId, status])
}

model EventStaff {
  eventId   String   @db.Char(36)
  userId    String   @db.Char(36)
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([eventId, userId])
  @@index([userId])
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Char(36)
  actorId    String?     @db.Char(36)
  action     AuditAction
  entityType String      @db.VarChar(80)
  entityId   String      @db.VarChar(100)
  metadata   Json?
  ipAddress  String?     @db.VarChar(64)
  userAgent  String?     @db.Text
  createdAt  DateTime    @default(now())
  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}

model IdempotencyRecord {
  id           String   @id @default(uuid()) @db.Char(36)
  userId       String   @db.Char(36)
  scope        String   @db.VarChar(80)
  key          String   @db.VarChar(100)
  resourceId   String?  @db.Char(36)
  responseCode Int?
  responseJson Json?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  @@unique([userId, scope, key])
  @@index([expiresAt])
}

model MediaDeletion {
  id          String   @id @default(uuid()) @db.Char(36)
  objectKey   String   @unique @db.VarChar(500)
  attempts    Int      @default(0)
  lastError   String?  @db.Text
  nextRetryAt DateTime @default(now())
  createdAt   DateTime @default(now())
  @@index([nextRetryAt])
}
