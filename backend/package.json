{
  "name": "event-tickets-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/src/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "npm run build && node dist/prisma/seed.js",
    "openapi:generate": "npm run build && node dist/scripts/generate-openapi.js"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.6",
    "@nestjs/throttler": "6.5.0",
    "@prisma/adapter-mariadb": "7.9.0",
    "@prisma/client": "7.9.0",
    "better-auth": "1.6.23",
    "dotenv": "17.4.2",
    "helmet": "8.3.0",
    "minio": "8.0.7",
    "morgan": "1.11.0",
    "nestjs-pino": "4.6.1",
    "nestjs-zod": "5.4.0",
    "nodemailer": "9.0.3",
    "pino-http": "10.5.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.18.0",
    "@types/nodemailer": "^7.0.1",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "pino-pretty": "^13.1.1",
    "prisma": "7.9.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.42.0",
    "vitest": "3.2.7"
  },
  "prisma": {
    "seed": "npm run seed"
  }
}
